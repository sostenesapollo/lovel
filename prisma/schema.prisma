generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  ADMIN
  CUSTOMER
}

enum UserStatus {
  ACTIVE
  REVOKED
}

enum OrderStatus {
  pending_payment
  paid
  shipped
  delivered
  cancelled
}

model User {
  id           String               @id @default(cuid())
  email        String               @unique
  passwordHash String
  name         String
  role         UserRole             @default(CUSTOMER)
  status       UserStatus           @default(ACTIVE)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  orders       Order[]
  emailLogs    EmailLog[]
  resetTokens  PasswordResetToken[]

  @@index([status])
  @@index([createdAt(sort: Desc)])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Category {
  id             String   @id @default(cuid())
  slug           String   @unique
  title          String
  subtitle       String   @default("")
  image          String   @default("")
  showOnHome     Boolean  @default(true)
  sortOrder      Int      @default(0)
  /// Labels de volumetria disponíveis nesta categoria, ex.: ["4ml","10ml","100ml"]
  variantLabels  Json     @default("[]")
  /// Subcategorias: [{ "slug": "arabes", "label": "Árabes" }]
  subcategories  Json     @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([showOnHome])
  @@index([sortOrder])
}

model Product {
  id             String   @id
  slug           String   @unique
  brand          String
  name           String
  type           String
  subcategory    String   @default("")
  category       String
  image          String
  images         Json
  description    String   @default("")
  notes          Json?
  badges         Json     @default("[]")
  variants       Json
  defaultVariant Int      @default(0)
  featured       Boolean  @default(false)
  isLaunch       Boolean  @default(false)
  soldOut        Boolean  @default(false)
  active         Boolean  @default(true)
  promoText      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([type])
  @@index([featured])
  @@index([isLaunch])
  @@index([active])
}

model Coupon {
  code              String  @id
  type              String
  value             Float
  minOrder          Float   @default(0)
  firstPurchaseOnly Boolean @default(false)
  description       String?
  active            Boolean @default(true)
}

model Order {
  id              String      @id
  userId          String?
  user            User?       @relation(fields: [userId], references: [id])
  userEmail       String?
  customer        Json
  items           Json
  payment         String
  paymentId       String?
  pixQrCode       String?
  pixQrCodeBase64 String?
  coupon          Json?
  subtotal        Float
  discount        Float       @default(0)
  shipping        Float       @default(0)
  total           Float
  status          OrderStatus @default(pending_payment)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([userId])
  @@index([userEmail])
  @@index([status])
  @@index([paymentId])
  @@index([createdAt(sort: Desc)])
}

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model EmailLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  userEmail String
  template  String
  subject   String
  sentAt    DateTime @default(now())

  @@index([userEmail])
  @@index([sentAt(sort: Desc)])
}
