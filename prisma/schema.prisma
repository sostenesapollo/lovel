generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String               @id @default(cuid())
  email         String               @unique
  passwordHash  String
  name          String
  role          UserRole             @default(CUSTOMER)
  status        UserStatus           @default(ACTIVE)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  /// null = conta criada no pedido, ainda sem senha escolhida
  passwordSetAt DateTime?
  emailLogs     EmailLog[]
  orders        Order[]
  resetTokens   PasswordResetToken[]

  @@index([status])
  @@index([createdAt(sort: Desc)])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Category {
  id            String   @id @default(cuid())
  slug          String   @unique
  title         String
  subtitle      String   @default("")
  image         String   @default("")
  showOnHome    Boolean  @default(true)
  sortOrder     Int      @default(0)
  /// Labels de volumetria disponíveis nesta categoria, ex.: ["4ml","10ml","100ml"]
  variantLabels Json     @default("[]")
  /// Subcategorias: [{ "slug": "arabes", "label": "Árabes" }]
  subcategories Json     @default("[]")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([showOnHome])
  @@index([sortOrder])
}

model Product {
  id             String   @id
  slug           String   @unique
  brand          String
  name           String
  type           String
  /// Slug principal (primeiro de subcategories) — compatibilidade
  subcategory    String   @default("")
  /// Slugs de todas as subcategorias: ["arabes","grifes"]
  subcategories  Json     @default("[]")
  category       String
  image          String
  images         Json
  description    String   @default("")
  notes          Json?
  badges         Json     @default("[]")
  variants       Json
  defaultVariant Int      @default(0)
  featured       Boolean  @default(false)
  isLaunch       Boolean  @default(false)
  soldOut        Boolean  @default(false)
  active         Boolean  @default(true)
  promoText      String?
  /// Soft-delete: null = ativo; data = removido (não aparece no storefront nem na listagem default do admin)
  deletedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([type])
  @@index([featured])
  @@index([isLaunch])
  @@index([active])
  @@index([deletedAt])
}

model Coupon {
  code              String  @id
  type              String
  value             Float
  minOrder          Float   @default(0)
  firstPurchaseOnly Boolean @default(false)
  description       String?
  active            Boolean @default(true)
}

model Order {
  id              String      @id
  userId          String?
  userEmail       String?
  customer        Json
  items           Json
  payment         String
  coupon          Json?
  subtotal        Float
  discount        Float       @default(0)
  shipping        Float       @default(0)
  total           Float
  status          OrderStatus @default(pending_payment)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  paymentId       String?
  pixQrCode       String?
  pixQrCodeBase64 String?
  user            User?       @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userEmail])
  @@index([status])
  @@index([paymentId])
  @@index([createdAt(sort: Desc)])
}

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model EmailLog {
  id        String   @id @default(cuid())
  userId    String?
  userEmail String
  template  String
  subject   String
  sentAt    DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userEmail])
  @@index([sentAt(sort: Desc)])
}

enum UserRole {
  ADMIN
  CUSTOMER
}

enum UserStatus {
  ACTIVE
  REVOKED
}

enum OrderStatus {
  pending_payment
  paid
  shipped
  delivered
  cancelled
}
