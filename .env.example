# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
AUTH_SECRET=change-me-in-production
CRON_SECRET=change-me-admin-secret

# Database (SQLite — prod volume at /app/data)
DATABASE_URL="file:./dev.db"

# Cloudflare R2 (upload de imagens de produtos)
STORAGE_ACCESS_KEY=
STORAGE_SECRET=
STORAGE_REGION=auto
STORAGE_BUCKET=lovel
STORAGE_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
STORAGE_PUBLIC_URL=https://pub-YOUR.r2.dev/lovel
NEXT_PUBLIC_STORAGE_PUBLIC_URL=https://pub-YOUR.r2.dev/lovel
R2_MAX_UPLOAD_BYTES=10485760

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM=LOVEL <noreply@lovel.com>

# ntfy — alertas de cadastro/pedidos
# https://ntfy.sh/lovelessence
NTFY_TOPIC=lovelessence

# Mercado Pago (PIX)
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_PUBLIC_KEY=
MERCADO_PAGO_NOTIFICATION_URL=https://lovel.giftsqr.com/api/mercadopago/webhook
MERCADO_PAGO_WEBHOOK_SECRET=

# Analytics — GA4 + Google Ads (eventos ecommerce: view_item, add_to_cart, begin_checkout, purchase)
# Depois importe as conversões no Ads / vincule AdSense no mesmo GA4
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_PURCHASE_CONVERSION_LABEL=
