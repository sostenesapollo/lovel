# App
NEXT_PUBLIC_APP_URL=http://localhost:4455
AUTH_SECRET=change-me-in-production
CRON_SECRET=change-me-admin-secret

# Porta local (next dev / next start) — evita conflito com outros apps na 3000
PORT=4455

# Database (SQLite — prod volume at /app/data)
# Relativo à raiz do projeto (runtime + prisma CLI com cwd em ~/…/lovel)
DATABASE_URL="file:./prisma/dev.db"

# Cloudflare R2 (upload de imagens de produtos)
STORAGE_ACCESS_KEY=
STORAGE_SECRET=
STORAGE_REGION=auto
STORAGE_BUCKET=lovel
STORAGE_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
STORAGE_PUBLIC_URL=https://pub-YOUR.r2.dev/lovel
NEXT_PUBLIC_STORAGE_PUBLIC_URL=https://pub-YOUR.r2.dev/lovel
R2_MAX_UPLOAD_BYTES=10485760

# Email (Resend) — set in Coolify / PRODUCTION_ENV, never commit the real key
RESEND_API_KEY=
RESEND_FROM=LOVEL <noreply@lovelessence.com>

# ntfy — alertas de cadastro/pedidos
# https://ntfy.sh/lovelessence
NTFY_TOPIC=lovelessence

# Mercado Pago (PIX + Checkout Pro cartão) — mesmas credenciais da giftsqr em prod
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_PUBLIC_KEY=
MERCADO_PAGO_NOTIFICATION_URL=https://lovelessence.com/api/mercadopago/webhook
MERCADO_PAGO_WEBHOOK_SECRET=

# Stripe (PIX fallback se MP falhar / não configurado) — mesmas keys da giftsqr
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SIGNING_SECRET=
# STRIPE_PIX_EXPIRES_AFTER_SECONDS=86400

# Analytics — GA4 + Google Ads (eventos ecommerce: view_item, add_to_cart, begin_checkout, purchase)
# Coolify: NEXT_PUBLIC_GA4_MEASUREMENT_ID (runtime via /api/tracking-config)
# Ads: vincule a property GA4 e importe o evento purchase como conversão primária
#        OU crie conversão Website e preencha AW + label abaixo
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-G99YVC9PDX
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_PURCHASE_CONVERSION_LABEL=
# Measurement Protocol (webhooks PIX/cartão) — Admin GA4 → Data stream → MP API secrets
GA4_API_SECRET=
